# 凭证模板 —— 复制为 .env.local（已被 .gitignore 忽略）填入真实值。
#   cp .env.example .env.local && 编辑      （或在 Agent 里说「帮我配置工作区」走引导）
# scripts/ 下的脚本会自动 source 仓库根的 .env.local，定时任务也能无人值守拿到 key。
# 本模板不含任何真实 key/账号。按你实际用到的来源填写即可，用不到的留空。
#
# 多租户（同一平台多套身份）：
#   • 飞书：用 lark-cli profile（凭证在 ~/.lark-cli，不进 .env），在 FEISHU_TENANTS 里列举要拉的 profile。
#   • 钉钉/腾讯会议/得到/生图等「凭证写在 .env」的来源：把另一套写到 .env.<租户>.local，
#     运行时 `TENANT=<租户> 脚本` 会在默认 .env.local 之上叠加该文件（.env.*.local 已被忽略）。

# ---- 飞书 (lark-cli) ----
# 凭证由 lark-cli 自己管理（存 ~/.lark-cli），本仓库不存任何 app-secret。
# 多租户模型：每个租户 = 一个 lark-cli profile，profile 名 == 租户目录名。
# 加一个租户：scripts/feishu-add-tenant.sh <租户名>（引导式，隐藏输入 secret）。
FEISHU_TENANTS=""              # 要拉取的 profile 列表（空格/逗号分隔，每个 = sources/feishu/<名>/）；留空=用当前 active profile
# 例：FEISHU_TENANTS="acme globex"
# FEISHU_TENANT=default        # 仅单租户回退：不设 FEISHU_TENANTS 时落到这个目录名（用当前 active profile）
FEISHU_SINCE_DAYS=1
FEISHU_MAX_CHATS=50

# ---- 得到 / Get笔记 (Biji OpenAPI) ----
GET_BIJI_API_KEY=
GET_BIJI_CLIENT_ID=
GET_BIJI_DEFAULT_TOPIC_ID=
# GETNOTE_SINCE_ID=0

# ---- 微信聊天 (chatlog) ----
CHATLOG_BASE_URL=http://127.0.0.1:5030
WECHAT_SINCE_DAYS=1
WECHAT_MAX_SESSIONS=50            # 最多处理多少个会话

# ---- 小宇宙播客 (xiaoyuzhou 技能，交互式扫码) ----
XIAOYUZHOU_OUTPUT_DIR=sources/social   # 播客 markdown 落到社媒来源
# 凭据存 ~/.xiaoyuzhou/（仓库外）；依赖 pip install requests qrcode pillow

# ---- 微信公众号导出 (wechat-exporter 技能，交互式扫码) ----
# 无需 env：会话存 .tmp/（gitignored），产物落 sources/mp/<公众号名>/
# 依赖 pip install requests openpyxl（可选 markdownify beautifulsoup4）

# ---- 钉钉归档 (dingtalk 技能，自建企业内部应用) ----
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_TENANT=default            # 落盘目录名 sources/dingtalk/<租户>/
DINGTALK_ARCHIVE=contacts          # 要归档什么，csv：contacts,docs
# 需管理员授予：通讯录读权限（部门/成员）；归档 docs 还需知识库/钉盘读权限
# 钉钉不开放历史聊天记录 API，本技能不拉聊天

# ---- 腾讯会议归档 (tencent-meeting 技能，企业版/商业版自建应用 AKSK) ----
TENCENT_MEETING_APP_ID=
TENCENT_MEETING_SDK_ID=
TENCENT_MEETING_SECRET_ID=
TENCENT_MEETING_SECRET_KEY=
TENCENT_MEETING_OPERATOR_ID=          # 操作者 userid（录制创建者，或有企业录制管理权限者）
TENCENT_MEETING_OPERATOR_ID_TYPE=1    # 1=userid 2=openid 3=rooms_id
TENCENT_MEETING_SINCE_DAYS=7          # 拉最近 N 天录制（最大 31）
# 凭证从 用户中心→企业管理→高级→REST API 获取；2026-01-16 后新建的应用还需 STS-Token（见技能说明）

# ---- 博客 / RSS 归档 (blog 技能，无需凭证) ----
# 逗号分隔：feed URL 或站点主页 URL（主页会自动发现 feed）；产物落 sources/blog/
BLOG_FEEDS=
BLOG_MAX_POSTS=20                  # 每个 feed 最多归档多少篇
BLOG_SINCE_DAYS=                   # 跳过早于 N 天的条目（空 = 不限制）
# 可选依赖（缺则降级运行）：pip install feedparser trafilatura markdownify
# 知乎专栏/语雀等无公开 RSS 的源：用 RSSHub 生成 feed 再填入 BLOG_FEEDS

# ---- AI 生图 (aiproxy / OpenAI 兼容) ----
AIPROXY_API_KEY=
AIPROXY_BASE_URL=https://your-host        # 脚本会自动拼 /v1/images/generations
# AIPROXY_ENDPOINT=                        # 可选：完整 URL 覆盖（逗号分隔多个做兜底）
# AIPROXY_MODEL=gpt-image-2
# AIPROXY_FALLBACK_MODEL=gemini-3.1-flash-image

# ---- 一键编排 (pull-all) ----
# PULL_SOURCES 通常是「运行时」覆盖，不必常驻这里；如要默认值可取消注释：
# PULL_SOURCES="feishu getnote wechat"     # 可纳入 dingtalk / tencent-meeting / blog
